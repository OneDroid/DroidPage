      {
        "key": "border_color",
        "label": "Border / Divider",
        "default": "#e2e8f0",
        "description": "Card borders, dividers"
      },
      {
        "key": "header_bg",
        "label": "Header Background",
        "default": "#0f172a",
        "description": "Top navigation bar"
      },
      {
        "key": "footer_bg",
