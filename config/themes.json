[
  {
    "id": "droidpage-default",
    "name": "DroidPage Default",
    "description": "The official DroidPage default theme.",
    "thumbnail": "templates/droidpage-default/assets/screenshots/notes_list.png",
    "path": "templates/droidpage-default/",
    "features": ["maxWidth"],
    "colorVars": [
      {
        "key": "primary_color",
        "label": "Primary / Accent",
        "default": "#3b82f6",
